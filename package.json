{
  "name": "aquaclaw-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pages:dev": "npm run build && npx wrangler pages dev dist --d1=DB --persist-to=.wrangler/state --port=8788",
    "pages:deploy": "npm run build && npx wrangler pages deploy dist --d1=DB",
    "db:init": "npx wrangler d1 execute aquaclaw-db --local --file=db/schema.sql",
    "db:seed": "npx wrangler d1 execute aquaclaw-db --local --file=db/seed.sql",
    "db:init:remote": "npx wrangler d1 execute aquaclaw-db --remote --file=db/schema.sql",
    "db:seed:remote": "npx wrangler d1 execute aquaclaw-db --remote --file=db/seed.sql"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.14.0",
    "opencc-js": "^1.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wrangler": "^4.87.0"
  }
}
